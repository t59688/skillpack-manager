{
  "name": "@skillpack/cli",
  "version": "0.4.1",
  "description": "Open-source CLI for packaging, sharing, installing, auditing, and syncing AI agent skill packs.",
  "type": "module",
  "bin": {
    "skillpack": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "DESIGN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "skills",
    "skillpack",
    "cli",
    "claude",
    "cursor",
    "codex"
  ],
  "author": "SkillPack",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t59688/skillpack-manager.git"
  },
  "homepage": "https://github.com/t59688/skillpack-manager#readme",
  "bugs": {
    "url": "https://github.com/t59688/skillpack-manager/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@inquirer/prompts": "^7.10.1",
    "adm-zip": "^0.5.16",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.0",
    "ora": "^8.1.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
